# Production env for infra/docker-compose.prod.yml.
# Copy to infra/.env.prod and fill in secrets, then deploy with:
#   docker compose -f infra/docker-compose.prod.yml --env-file infra/.env.prod up -d --build

# ── Secrets (REQUIRED — generate strong values, e.g. `openssl rand -base64 24`) ──
POSTGRES_PASSWORD=change-me-postgres
RABBITMQ_PASSWORD=change-me-rabbitmq

# ── Usernames (optional; defaults shown) ──
POSTGRES_USER=sofin
RABBITMQ_USER=sofin

# ── Public hostnames for Caddy (point DNS A records at the EC2 Elastic IP) ──
# Real domains → automatic HTTPS. Leave as *.localhost for a no-DNS smoke test.
API_DOMAIN=api.example.com
APP_DOMAIN=app.example.com
ADMIN_DOMAIN=admin.example.com

# ── App config ──
TOKEN_ISSUER=sofin-auth
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800
RABBITMQ_EXCHANGE=sofin.events
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Per-service Swagger UI — keep disabled in production.
SWAGGER_ENABLED=false
