generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@sofin/prisma-crm"
}

datasource db {
  provider = "postgresql"
  url      = env("CRM_DATABASE_URL")
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  ownerId   String
  createdAt DateTime @default(now())
}

model Deal {
  id        String   @id @default(uuid())
  contactId String
  title     String
  amount    Float?
  stage     String   @default("lead")
  ownerId   String
  createdAt DateTime @default(now())

  @@index([contactId])
}

model Activity {
  id        String   @id @default(uuid())
  contactId String
  type      String
  payload   Json
  createdAt DateTime @default(now())

  @@index([contactId])
}

// Transactional outbox: events written in the same tx as the business change,
// published by OutboxRelay. The row id becomes the event id.
model Outbox {
  id            String    @id @default(uuid())
  type          String
  payload       Json
  producer      String
  correlationId String?
  createdAt     DateTime  @default(now())
  publishedAt   DateTime?

  @@index([publishedAt])
}
