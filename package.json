{
  "name": "sofin",
  "version": "0.1.0",
  "private": true,
  "description": "Sofin microservices platform (NestJS)",
  "scripts": {
    "prisma:generate": "prisma generate --schema apps/auth-sso/prisma/schema.prisma && prisma generate --schema apps/lms/prisma/schema.prisma && prisma generate --schema apps/crm/prisma/schema.prisma && prisma generate --schema apps/notification/prisma/schema.prisma",
    "db:push": "prisma db push --schema apps/auth-sso/prisma/schema.prisma && prisma db push --schema apps/lms/prisma/schema.prisma && prisma db push --schema apps/crm/prisma/schema.prisma && prisma db push --schema apps/notification/prisma/schema.prisma",
    "build": "npm run prisma:generate && nest build gateway && nest build auth-sso && nest build lms && nest build crm && nest build notification",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "stack:up": "docker compose -f infra/docker-compose.yml --profile apps up -d --build",
    "start:gateway": "nest start gateway --watch",
    "start:auth": "nest start auth-sso --watch",
    "start:lms": "nest start lms --watch",
    "start:crm": "nest start crm --watch",
    "start:notif": "nest start notification --watch",
    "dev": "concurrently -n auth,gateway,lms,crm,notif -c green,cyan,magenta,yellow,blue \"npm:start:auth\" \"npm:start:gateway\" \"npm:start:lms\" \"npm:start:crm\" \"npm:start:notif\""
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.4",
    "@prisma/client": "^5.22.0",
    "amqplib": "^0.10.4",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express-rate-limit": "^7.4.1",
    "http-proxy-middleware": "^2.0.7",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@types/amqplib": "^0.10.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.16.0",
    "concurrently": "^9.1.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
