# Ports
GATEWAY_PORT=8080
AUTH_PORT=4001
LMS_PORT=4002
CRM_PORT=4003
NOTIF_PORT=4004

# Internal service URLs (used by the gateway)
AUTH_URL=http://localhost:4001
LMS_URL=http://localhost:4002
CRM_URL=http://localhost:4003
NOTIF_URL=http://localhost:4004

# Auth
ACCESS_TOKEN_TTL=900          # 15 min (seconds)
REFRESH_TOKEN_TTL=604800      # 7 days (seconds)
TOKEN_ISSUER=sofin-auth

# Gateway
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# API docs (Swagger) — per-service at /docs; set false in production
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# Databases (one per service) — point at the docker-compose Postgres (port 5544)
AUTH_DATABASE_URL=postgresql://sofin:sofin@localhost:5544/auth
LMS_DATABASE_URL=postgresql://sofin:sofin@localhost:5544/lms
CRM_DATABASE_URL=postgresql://sofin:sofin@localhost:5544/crm
NOTIF_DATABASE_URL=postgresql://sofin:sofin@localhost:5544/notification

# Message broker — when set, services use RabbitMQ; unset → in-process EventBus
RABBITMQ_URL=amqp://sofin:sofin@localhost:5672
RABBITMQ_EXCHANGE=sofin.events
